<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.ailing2416.sentinel</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Sentinel</name>
  <summary>Secure GNOME SSH connection manager</summary>
  <description>
    <p>
      Sentinel is a native GNOME SSH connection manager focused on security and aesthetics.
      It integrates with password managers like Bitwarden to keep your credentials safe.
    </p>
    <ul>
      <li>Native libadwaita UI</li>
      <li>Bitwarden vault integration</li>
      <li>Secure memory handling for credentials</li>
      <li>Integrated VTE terminal with multi-tab support</li>
      <li>SFTP file browser with drag-and-drop</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.ailing2416.sentinel.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <caption>Main Window</caption>
      <image>https://raw.githubusercontent.com/ailing2416/sentinel/main/data/screenshots/main.png</image>
    </screenshot>
  </screenshots>
  <url type="vcs-browser">https://github.com/ailing2416/sentinel</url>
  <recommends>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </recommends>
  <requires>
    <id>com.bitwarden.desktop</id>
  </requires>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.2.5" date="2026-03-31">
      <description>
        <ul>
          <li>SFTP rewrite: clean concurrency model with separate metadata lock and transfer semaphore</li>
          <li>SFTP edit workflow: rclone copyto downloads file to /tmp for external editor, monitors changes and syncs back</li>
          <li>Rclone: read-write FUSE mount, stderr-based readiness detection, atomic tmpdir cleanup</li>
          <li>Rclone: implemented cross-host transfer and GLib cache dir for Flatpak compatibility</li>
          <li>File browser: fixed row selection bug after sorting, drag-and-drop upload, split new-file/new-folder actions</li>
        </ul>
      </description>
    </release>
    <release version="0.2.4" date="2026-03-29">
      <description>
        <ul>
          <li>Zen Mode Welcome Page: redesigned home screen for a focused, minimalist experience</li>
          <li>GNOME Light Terminal Theme: new preset matching the Adwaita light palette</li>
          <li>Fixed translation error mislabelling Hostname fields as Username in English locale</li>
          <li>Optimised local PTY resizing and fixed terminal tab closing behaviour</li>
        </ul>
      </description>
    </release>
    <release version="0.2.3" date="2026-03-29">
      <description>
        <ul>
          <li>Fixed Bitwarden session restoration and login crash (NameError)</li>
          <li>Improved local vault lockout recovery with a new 'Reset' option in the UI</li>
          <li>Enhanced 2FA flow and error handling for CLI-managed sessions</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-03-26">
      <description>
        <ul>
          <li>Fixed Bitwarden Vault auto-unlocking logic for Flatpak due to excessive Keyring permission</li>
          <li>Fixed language switching and missing i18n .mo files in Flatpak runtime</li>
          <li>Removed error-prone legacy JSON payload fallback in decryptor</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-03-25">
      <description>
        <ul>
          <li>Enhanced security: Zero-string copy memory management</li>
          <li>Refactored Secure Vault with binary packing</li>
          <li>Improved terminal keyboard handling and theme consistency</li>
          <li>Added German and Traditional Chinese translations</li>
          <li>Process-level credential protection improvements</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-03-12" />
  </releases>
  <developer_name>ailing2416</developer_name>
  <update_contact>ailing2416@github.com</update_contact>
</component>
