#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# Sentinel — GNOME SSH Connection Manager

"""Application entry point."""

import os
import sys

# These are replaced by Meson if installed
pkgdatadir = '@pkgdatadir@'
version = '@VERSION@'
application_id = '@application_id@'
module_dir = '@PYTHONDIR@'

# If running from source, these won't be replaced
if pkgdatadir.startswith('@'):
    _src_dir = os.path.dirname(os.path.abspath(__file__))
    if _src_dir not in sys.path:
        sys.path.insert(0, _src_dir)
else:
    # If installed, add the sentinel package content directory to path.
    # This allows absolute imports like 'import views' which are used in the project.
    if module_dir not in sys.path:
        sys.path.insert(0, module_dir)


def _setup_language() -> None:
    import gettext
    import locale
    # We no longer read from DB to follow GNOME/Flatpak standards
    lang_code = os.environ.get("LANGUAGE", "")

    domain = 'sentinel'
    localedir = os.path.join(pkgdatadir, 'locale') if not pkgdatadir.startswith('@') else os.path.join(_src_dir, '..', 'build', 'locale')

    print(f"DEBUG_I18N: lang_code environment = '{lang_code}'", flush=True)
    print(f"DEBUG_I18N: localedir = '{localedir}'", flush=True)

    # 1. Initialize the default system locale
    try:
        locale.setlocale(locale.LC_ALL, "")
    except locale.Error as e:
        print(f"DEBUG_I18N: setlocale empty error: {e}", flush=True)

    # Initialize gettext for Python side
    gettext.bindtextdomain(domain, localedir)
    gettext.textdomain(domain)
    
    # Verify Python side before importing application
    test_trans = gettext.gettext("Settings")
    print(f"DEBUG_I18N: Global gettext('Settings') test: '{test_trans}'", flush=True)
    
    # Initialize gettext for C side (GTK/GLib)
    if hasattr(locale, 'bindtextdomain'):
        try:
            locale.bindtextdomain(domain, localedir)
            locale.textdomain(domain)
        except Exception as e:
            print(f"DEBUG_I18N: locale.bindtextdomain error: {e}", flush=True)
    
    # The C components (like GLib/Gtk) will automatically pick up the LANGUAGE env var early on
    
    # The C components (like GLib/Gtk) will automatically pick up the LANGUAGE env var early on

# ALWAYS SETUP LANGUAGE FIRST, BEFORE IMPORTING GTK OR LIBADWAITA
_setup_language()

import gi

gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")

from application import SentinelApplication  # noqa: E402



def main() -> int:
    """Launch the Sentinel application."""
    import logging
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s [%(levelname)s] %(name)s: %(message)s',
        datefmt='%H:%M:%S'
    )
    logger = logging.getLogger("Sentinel")
    logger.info("Application starting (Flatpak)...")

    # Initialize and attempt auto-unlock of local secure vault
    try:
        from services.vault_manager import VaultManager
        vm = VaultManager.get()
        if vm.startup():
            logger.info("Local vault: auto-unlocked via keyring.")
        else:
            logger.info("Local vault: manual unlock required (will prompt in UI).")
    except Exception as _ve:
        logger.warning("Local vault startup failed: %s", _ve)

    app = SentinelApplication()
    ret = app.run(sys.argv)

    try:
        from services.rclone_service import RcloneService
        RcloneService.get().unmount_all()
    except Exception as e:
        import logging
        logging.error(f"Failed to unmount active FUSE directories: {e}")

    return ret


if __name__ == "__main__":
    sys.exit(main())
